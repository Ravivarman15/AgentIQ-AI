# ═══════════════════════════════════════════════════════════════════════════════
# AGENTIQ AI — Backend Environment Variables Template
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# HuggingFace (Required for LLM & embeddings)
HUGGINGFACEHUB_API_TOKEN=
HF_MODEL_REPO=meta-llama/Meta-Llama-3-8B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Supabase Configuration
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase Database (individual components — handles special chars in password)
SUPABASE_DB_HOST=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_USER=postgres
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres

# Alternative: Full database connection URL (encode special chars yourself)
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@host:5432/postgres?sslmode=require

# JWT Authentication
SECRET_KEY=your-strong-secret-key-change-in-production

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Storage Paths
UPLOAD_DIR=uploads
MODELS_DIR=models
REPORTS_DIR=reports

# RAG Pipeline
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=80
