# ═══════════════════════════════════════════════════════════════════════════════
# AGENTIQ AI — Backend Environment Variables Template
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# HuggingFace (Required for LLM & embeddings)
HUGGINGFACEHUB_API_TOKEN=
HF_MODEL_REPO=meta-llama/Meta-Llama-3-8B-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# If huggingface.co is blocked/unreachable in your network, use the mirror:
# HF_ENDPOINT=https://hf-mirror.com

# JWT Authentication
SECRET_KEY=your-strong-secret-key-change-in-production

# Database (SQLite — local, zero config)
SQLITE_DB_PATH=agentiq.db

# Vector Database (ChromaDB — local persistent storage)
CHROMA_DB_DIR=./chroma_db

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Storage Paths
UPLOAD_DIR=uploads
MODELS_DIR=models
REPORTS_DIR=reports

# RAG Pipeline
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=80
